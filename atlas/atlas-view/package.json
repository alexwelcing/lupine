{
  "name": "atlas-view",
  "version": "0.2.1",
  "private": true,
  "description": "WebGPU-powered LAMMPS molecular dynamics visualization platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/atlas-sim/atlas-view.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "start": "serve -s apps/web/dist -p ${PORT:-8080}",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:wasm": "cd packages/parsers/wasm && wasm-pack build --target web --out-dir ../pkg",
    "test": "turbo run test",
    "test:rust": "cd packages/parsers/wasm && cargo test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@react-three/test-renderer": "^9.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@webgpu/types": "^0.1.69",
    "jsdom": "^29.1.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@types/node": "^22.0.0",
    "leva": "^0.10.1",
    "serve": "^14.2.6"
  }
}
