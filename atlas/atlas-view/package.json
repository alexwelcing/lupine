{
  "name": "atlas-view",
  "version": "0.1.0",
  "private": true,
  "description": "WebGPU-powered LAMMPS molecular dynamics visualization platform",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/atlas-sim/atlas-view.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:wasm": "cd packages/parsers/wasm && wasm-pack build --target web --out-dir ../pkg",
    "test": "turbo run test",
    "test:rust": "cd packages/parsers/wasm && cargo test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
