---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const pipelineNodes = [
  { title: 'DFT Training', progress: 100 },
  { title: 'MACE Potential', progress: 100 },
  { title: 'Production MD', progress: 100 },
  { title: 'Analysis', progress: 100 }
];

const pipelineLogs = [
  { text: '> Generating high-accuracy ground truth data sets (EST: 120h GPU).' },
  { text: '> Equivariant neural network message passing (EST: 14h TRAINING).' },
  { text: '> Large-scale molecular dynamics at scale (EST: 4h / CANDIDATE).' },
  { text: '> Automated MS-diffusion & conductivity metrics (EST: REAL-TIME).' }
];

const metrics = [
  { parameter: 'Candidates Screened', reference: 'N/A', observed: '1,200', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Stable Conductors', reference: 'N/A', observed: '3 Novel', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Speed Improvement', reference: '1x (DFT)', observed: '100x', delta: '+9900%', deltaState: 'good' as const },
  { parameter: 'Atom Accuracy', reference: 'N/A', observed: 'Sub-meV', delta: 'High', deltaState: 'good' as const }
];
---

<BaseLayout title="Solid-State Electrolytes | Lupine Research">
  <FormalBrief
    sealText="LMS // SOLID-STATE ELECTROLYTES"
    title="Solid-State Electrolytes"
    subtitle="Accelerating ion conductivity analysis using ML-backed molecular dynamics at 100x DFT speed."
  >
    <div slot="marginalia">
      <p>The search for stable, highly conductive solid electrolytes is paralyzed by the computational cost of Density Functional Theory (DFT).</p>
    </div>

    <section class="manuscript-section">
      <p>
        Traditional DFT requires ~2.5 months per candidate material simulation. By leveraging the Lupine ML-MD pipeline, we reduce this to 18 hours, providing high-fidelity predictive screening for novel stable conductors.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <WorkflowTimeline 
        title="Methodology: Phased Pipeline Architecture"
        statusText="PIPELINE ACTIVE"
        nodes={pipelineNodes}
        logHeader="RUNTIME LOGS"
        logs={pipelineLogs}
      />
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Results Statistics"
        summary="Table 1.1: Accelerated material discovery metrics."
        headers={['Specification', 'Legacy Baseline', 'Lupine Value', 'Delta']}
        rows={metrics}
      />
    </section>
  </FormalBrief>
</BaseLayout>
