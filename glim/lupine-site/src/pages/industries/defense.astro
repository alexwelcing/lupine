---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const deploymentNodes = [
  { title: 'Cloud', icon: '☁️' },
  { title: 'On-Premise', icon: '🏢' },
  { title: 'Air-Gapped', icon: '🔒' }
];

const deploymentLogs = [
  { text: '> UNCLASSIFIED: High-velocity iteration labs, automated scaling to 10k cores.' },
  { text: '> CUI / ITAR: Sovereign data ownership, direct ITAR compliance control.' },
  { text: '> CLASSIFIED: Physically isolated networks, TS/SCI environment compatible.' }
];

const materialsData = [
  { parameter: 'Thermal Barriers', reference: 'Hypersonic Skins', observed: '3200°C Max', delta: 'Mach 5+', deltaState: 'good' as const },
  { parameter: 'Ballistics', reference: 'Next-Gen Armor', observed: '24.1 GPA', delta: '-42% Density', deltaState: 'good' as const },
  { parameter: 'Deep Space', reference: 'Rad-Hard Electronics', observed: '1.2 MRAD', delta: '25+ YRS', deltaState: 'good' as const },
  { parameter: 'Signature', reference: 'Stealth Coatings', observed: 'Ultra-Wide', delta: '-35 DB', deltaState: 'good' as const }
];
---

<BaseLayout title="Defense & Aerospace | Lupine Materials Science">
  <FormalBrief
    sealText="LMS // DEFENSE & AEROSPACE"
    title="Mission-Critical Defense Applications"
    subtitle="Secure, on-premise deployments of the Lupine materials simulation stack engineered for high-velocity research within classified environments."
  >
    <div slot="marginalia">
      <p>Compliant with ITAR, FedRAMP High-Authority, CMMC 2.0 Level 3, SOC 2 Type II, and NIST 800-171 protocols.</p>
    </div>

    <section class="manuscript-section">
      <p>
        The defense and aerospace sectors demand materials that can survive extreme environments: hypersonic flight regimes, deep-space radiation, and multi-hit kinetic impact. The Lupine system provides a 10,000+ core scaling capacity with sub-microsecond timestep integration to accelerate discovery cycles for these mission-critical applications.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <WorkflowTimeline 
        title="Infrastructure Architecture"
        statusText="DEPLOYMENT FLEXIBILITY"
        nodes={deploymentNodes}
        logHeader="SECURITY CLEARANCE LOGS"
        logs={deploymentLogs}
      />
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Catalog: 01-Materials"
        summary="Table 3.1: Material optimizations verified via the simulation stack."
        headers={['Category', 'Application', 'Primary Spec', 'Delta Focus']}
        rows={materialsData}
      />
    </section>
  </FormalBrief>
</BaseLayout>
