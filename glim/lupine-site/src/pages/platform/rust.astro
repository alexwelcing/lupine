---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import '../../styles/global.css';

const benchData = [
  { parameter: 'FORTRAN 90', reference: 'N/A', observed: '99.1%', delta: 'Legacy', deltaState: 'warn' as const },
  { parameter: 'C++20 (GCC)', reference: 'N/A', observed: '100.0% (Baseline)', delta: 'Legacy', deltaState: 'neutral' as const },
  { parameter: 'Rust (Stable)', reference: 'C++20', observed: '98.2%', delta: '-1.8%', deltaState: 'good' as const },
  { parameter: 'Python (NumPy)', reference: 'C++20', observed: '12.4%', delta: '-87.6%', deltaState: 'error' as const }
];
---

<BaseLayout title="Why We Chose Rust | Lupine">
  <FormalBrief
    sealText="LMS // SAFETY PROTOCOLS"
    title="Why We Chose Rust"
    subtitle="Memory safety, fearless concurrency, and robust WASM compilation are non-negotiable for modern scientific software."
  >
    <div slot="marginalia">
      <p>Undefined behavior in material discovery platforms compromises multi-million dollar research pipelines. Safety must be mathematical.</p>
    </div>

    <section class="manuscript-section">
      <p>
        Legacy scientific codes written in C++ or FORTRAN routinely lose massive compute hours to segmentation faults, manual pointer arithmetic errors, and silent data corruption. Rust operates as a mathematical proof assistant during compilation, guaranteeing memory safety and thread-safe concurrency without imposing runtime overhead. 
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <p class="mb-6">
        Comparing raw execution speed across common paradigms. Rust offers C-level performance while strictly prohibiting data races via the Send/Sync trait system and Rayon-based parallelization.
      </p>
      <ValidationTable 
        title="Lennard-Jones Kernel Benchmarks"
        summary="Table 3.1: Execution time indices for N-body force calculation."
        headers={['Language / Stack', 'Reference', 'Throughput Benchmark', 'Delta']}
        rows={benchData}
      />
    </section>
  </FormalBrief>
</BaseLayout>
