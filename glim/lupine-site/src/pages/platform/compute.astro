---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import '../../styles/global.css';

const gpuTable = [
  { parameter: 'Compute Capabilities', reference: 'Raster Only', observed: '[ UNLIMITED ]', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Max Atom Count', reference: '~250k', observed: '10M+ (Native)', delta: '40x', deltaState: 'good' as const },
  { parameter: 'Frame Rate', reference: '30fps (Instanced)', observed: '144HZ (Adaptive)', delta: '+114fps', deltaState: 'good' as const }
];
---

<BaseLayout title="WebGPU Compute | Lupine">
  <FormalBrief
    sealText="LMS // NATIVE COMPUTE"
    title="Browser Native GPU"
    subtitle="Delivering supercomputing performance directly to your browser with zero installation."
  >
    <div slot="marginalia">
      <p>The WGSL shader pipeline leverages massive parallelization to solve multi-body dynamics on the client GPU, bypassing traditional server latency.</p>
    </div>

    <section class="manuscript-section">
      <p>
        Historically, visualizing millions of atoms required downloading specialized desktop software and transferring massive datasets locally. By tapping into WebGPU, the Lupine View Engine executes physically based rendering and simulation calculations directly on the client machine, maintaining strict 60+ FPS stability across up to 10 million atomic instances.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Hardware Performance Spectrum"
        summary="Table 2.1: Performance benchmarks compared to traditional WebGL pathways."
        headers={['Capability', 'WebGL (Legacy)', 'WebGPU (Lupine)', 'Delta']}
        rows={gpuTable}
      />
    </section>
  </FormalBrief>
</BaseLayout>
