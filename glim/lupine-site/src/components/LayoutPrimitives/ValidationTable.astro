---
// src/components/LayoutPrimitives/ValidationTable.astro
export interface Props {
  title: string;
  summary?: string;
  headers: string[];
  rows: Array<{
    parameter: string;
    reference: string;
    observed: string;
    delta: string;
    deltaState?: 'good' | 'warn' | 'error' | 'neutral';
  }>;
}

const { title, summary, headers, rows } = Astro.props;
---

<div class="validation-table-container">
  <h2>{title}</h2>
  {summary && <p class="summary-text">{summary}</p>}
  <table class="validation-table">
    <thead>
      <tr>
        {headers.map(header => <th>{header}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map(row => (
        <tr>
          <td>{row.parameter}</td>
          <td class="data">{row.reference}</td>
          <td class="data">{row.observed}</td>
          <td class={`data highlight-${row.deltaState || 'neutral'}`}>{row.delta}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .validation-table-container {
    max-width: 900px;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .validation-table-container h2 {
    font-family: 'Newsreader', serif;
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: var(--space-xs);
  }

  .summary-text {
    font-family: 'Inter', sans-serif !important;
    font-size: 1rem !important;
    color: var(--on-surface-variant) !important;
    margin-bottom: var(--space-xl) !important;
    max-width: 100% !important;
  }

  .validation-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .validation-table th {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--on-surface-variant);
    padding: var(--space-md) var(--space-sm);
    border-bottom: 1px solid var(--outline-variant);
    font-weight: 600;
  }

  .validation-table td {
    padding: var(--space-md) var(--space-sm);
    border-bottom: 1px solid var(--outline-variant);
    font-family: 'Inter', sans-serif;
    color: var(--on-surface);
  }

  .validation-table td.data {
    font-family: 'Space Grotesk', monospace;
    font-variant-numeric: tabular-nums;
  }

  .highlight-good { color: var(--secondary); }
  .highlight-warn { color: var(--tertiary); }
  .highlight-error { color: var(--error); }
  .highlight-neutral { color: var(--on-surface); }

  @media (max-width: 800px) {
    .validation-table {
      display: block;
      overflow-x: auto;
    }
  }
</style>
