// Atom impostor sphere shader
// Each atom is rendered as a screen-aligned quad with ray-sphere intersection

struct CameraUniform {
    view_proj: mat4x4<f32>,
    camera_pos: vec3<f32>,
    _padding: f32,
};

@group(0) @binding(0)
var<uniform> camera: CameraUniform;

struct VertexInput {
    @location(0) position: vec3<f32>,
    @location(1) atom_type: u32,
    @location(2) radius: f32,
};

struct VertexOutput {
    @builtin(position) clip_position: vec4<f32>,
    @location(0) world_pos: vec3<f32>,
    @location(1) atom_center: vec3<f32>,
    @location(2) radius: f32,
    @location(3) color: vec3<f32>,
    @location(4) quad_uv: vec2<f32>,
};

// Type-based colors
const TYPE_COLORS: array<vec3<f32>, 8> = array<vec3<f32>, 8>(
    vec3<f32>(1.0, 0.3, 0.3),  // Type 0: Red
    vec3<f32>(0.3, 0.6, 1.0),  // Type 1: Blue
    vec3<f32>(0.3, 0.9, 0.4),  // Type 2: Green
    vec3<f32>(1.0, 0.8, 0.2),  // Type 3: Yellow
    vec3<f32>(0.9, 0.3, 0.9),  // Type 4: Magenta
    vec3<f32>(0.3, 0.9, 0.9),  // Type 5: Cyan
    vec3<f32>(1.0, 0.6, 0.3),  // Type 6: Orange
    vec3<f32>(0.7, 0.7, 0.7),  // Type 7: Gray
);

@vertex
fn vs_main(
    @builtin(vertex_index) vert_idx: u32,
    instance: VertexInput,
) -> VertexOutput {
    // Quad vertices (triangle strip: 0,1,2,3)
    var uvs = array<vec2<f32>, 4>(
        vec2<f32>(-1.0, -1.0),
        vec2<f32>( 1.0, -1.0),
        vec2<f32>(-1.0,  1.0),
        vec2<f32>( 1.0,  1.0),
    );
    
    let quad_uv = uvs[vert_idx];
    
    // Billboard calculation
    let view_dir = normalize(camera.camera_pos - instance.position);
    let up = vec3<f32>(0.0, 1.0, 0.0);
    let right = normalize(cross(view_dir, up));
    let billboard_up = cross(right, view_dir);
    
    let world_offset = (right * quad_uv.x + billboard_up * quad_uv.y) * instance.radius * 2.0;
    let world_pos = instance.position + world_offset;
    
    var out: VertexOutput;
    out.clip_position = camera.view_proj * vec4<f32>(world_pos, 1.0);
    out.world_pos = world_pos;
    out.atom_center = instance.position;
    out.radius = instance.radius;
    out.color = TYPE_COLORS[instance.atom_type % 8u];
    out.quad_uv = quad_uv;
    
    return out;
}

@fragment
fn fs_main(in: VertexOutput) -> @location(0) vec4<f32> {
    // Ray-sphere intersection
    let ray_origin = camera.camera_pos;
    let ray_dir = normalize(in.world_pos - ray_origin);
    
    let oc = ray_origin - in.atom_center;
    let a = dot(ray_dir, ray_dir);
    let b = 2.0 * dot(oc, ray_dir);
    let c = dot(oc, oc) - in.radius * in.radius;
    let discriminant = b * b - 4.0 * a * c;
    
    if (discriminant < 0.0) {
        discard;
    }
    
    let t = (-b - sqrt(discriminant)) / (2.0 * a);
    if (t < 0.0) {
        discard;
    }
    
    let hit_pos = ray_origin + ray_dir * t;
    let normal = normalize(hit_pos - in.atom_center);
    
    // Simple lighting
    let light_dir = normalize(vec3<f32>(0.5, 0.8, 0.3));
    let diffuse = max(dot(normal, light_dir), 0.0);
    let ambient = 0.3;
    let specular = pow(max(dot(reflect(-light_dir, normal), -ray_dir), 0.0), 32.0) * 0.3;
    
    let lighting = ambient + diffuse * 0.6 + specular;
    let color = in.color * lighting;
    
    // Rim lighting
    let rim = 1.0 - max(dot(normal, -ray_dir), 0.0);
    let rim_color = in.color * pow(rim, 3.0) * 0.5;
    
    return vec4<f32>(color + rim_color, 1.0);
}
