---
// src/components/LayoutPrimitives/FormalBrief.astro
export interface Props {
  title: string;
  subtitle?: string;
  sealText?: string;
}

const { title, subtitle, sealText } = Astro.props;
---

<div class="reference-container">
  <header class="formal-header">
    {sealText && <div class="seal">{sealText}</div>}
    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
  </header>

  <section class="reading-layout">
    <div class="marginalia">
      <slot name="marginalia" />
    </div>
    <article class="manuscript">
      <slot />
    </article>
  </section>
</div>

<style>
  .reference-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .formal-header {
    border-bottom: 1px solid var(--outline-variant);
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .seal {
    font-family: 'Space Grotesk', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--primary);
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .formal-header h1 {
    font-family: 'Newsreader', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--on-surface);
    margin: 0 0 var(--space-xs);
  }

  .subtitle {
    font-family: 'Inter', sans-serif;
    color: var(--on-surface-variant);
    font-size: 1.1rem;
  }

  .reading-layout {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .marginalia {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: var(--space-xl);
    position: sticky;
    top: var(--space-xl);
  }

  :global(.citation-note) {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    color: var(--on-surface-variant);
    line-height: 1.5;
    border-left: 2px solid var(--primary-container);
    padding-left: var(--space-sm);
  }

  .manuscript :global(h2) {
    font-family: 'Newsreader', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--on-surface);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .manuscript :global(h2:first-child) {
    margin-top: 0;
  }

  .manuscript :global(p) {
    font-family: 'Newsreader', serif;
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--on-surface);
    margin-bottom: var(--space-lg);
    max-width: 65ch;
  }

  :global(.equation-block) {
    background: var(--surface-container-low);
    padding: var(--space-xl);
    margin: var(--space-xl) 0;
    position: relative;
    max-width: 65ch;
  }

  :global(.math-label) {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    font-family: 'Space Grotesk', monospace;
    font-size: 0.75rem;
    color: var(--on-surface-variant);
    text-transform: uppercase;
  }

  :global(.math-body) {
    font-family: 'Newsreader', serif;
    font-style: italic;
    font-size: 1.5rem;
    text-align: center;
    color: var(--on-surface);
    margin-top: var(--space-md);
  }

  @media (max-width: 800px) {
    .reading-layout {
      grid-template-columns: 1fr;
    }
    .marginalia {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      border-top: 1px solid var(--outline-variant);
      padding-top: var(--space-md);
      margin-top: var(--space-md);
    }
  }
</style>
