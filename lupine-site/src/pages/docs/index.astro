---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const workflowNodes = [
  { title: 'Create Account', icon: '01' },
  { title: 'Upload Trajectory', icon: '02' },
  { title: 'Configure View', icon: '03' },
  { title: 'Share & Collaborate', icon: '04' }
];

const workflowLogs = [
  { text: '> $ lupine-cli auth login --scope="lab.sim"' },
  { text: '> $ lupine upload ./trajectories/run_01.dump --format="lammps" --label="Ni_Fe_Alloy"' },
  { text: '> Configure view: { "bond_threshold": 2.45, "renderer": "quantum_field", "occlusion": true }' },
  { text: '> $ lupine share sim_7721 --expires="7d"' },
  { text: '> https://share.lupine.dev/r/v2p9x...' }
];
---

<BaseLayout title="Documentation | Lupine Materials Science">
  <FormalBrief
    sealText="LMS // PRECISION LEDGER"
    title="From Zero to First Simulation in Five Minutes"
    subtitle="Everything you need to start exploring materials at the atomic scale. Our distributed quantum engine handles the compute; you handle the science."
  >
    <div slot="marginalia">
      <p class="font-mono text-[10px] tracking-widest text-secondary mb-2">QUICK START</p>
      <p>Initialize your laboratory environment at lupine.dev. Credentials are encrypted via AES-256 GCM. We support standard material science formats. Direct pipe from LAMMPS or raw .xyz snapshots.</p>
    </div>

    <section class="manuscript-section">
      <WorkflowTimeline 
        title="The Quantum Workflow"
        statusText="ORCHESTRATION SEQUENCE"
        nodes={workflowNodes}
        logHeader="SYSTEM LOGS & COMMANDS"
        logs={workflowLogs}
      />
    </section>
    
    <section class="manuscript-section mt-16">
      <h3>Quantum API Reference</h3>
      <p>Direct programmatic access to the material ledger. Query lattice constants, elastic tensors, and phonon spectra via our REST interface.</p>
      
      <div class="terminal-input mt-6" style="font-family: var(--font-mono); font-size: 0.85rem; padding: 1.5rem; background: var(--surface-container-low); border-radius: 4px; overflow-x: auto; border: 1px solid var(--outline-variant);">
<pre><code class="text-on-surface">curl -X POST "https://api.lupine.dev/v1/simulation" \
  -H "Authorization: Bearer $LUPINE_TOKEN" \
  -H "Content-Type: application/json" \
  -d '&#123;
    "element_id": "MoS2",
    "layer_count": 3,
    "strain_tensor": [0.01, 0, 0, 0, 0.01, 0, 0, 0, 0]
  &#125;'</code></pre>
      </div>
    </section>

    <section class="manuscript-section mt-16">
      <h3>Universal Integration</h3>
      <ul class="feature-list pl-6 list-disc space-y-4 mt-6">
        <li><strong>Python SDK:</strong> The researcher's choice. Integration with NumPy, ASE, and PyTorch Geometric. <code>pip install lupine-py</code></li>
        <li><strong>Rust Crate:</strong> Memory-safe, high-concurrency bindings for large trajectory processing. <code>cargo add lupine-rs</code></li>
        <li><strong>REST API:</strong> Cloud-agnostic interface for custom scientific dashboards and workflows. <em>Swagger/OpenAPI 3.0</em></li>
      </ul>
    </section>

    <section class="manuscript-section mt-16 border-t border-outline-variant/30 pt-8">
      <h3>Resource Library</h3>
      <p>Need help? Connect with 15k+ material scientists on our forum, read our peer-reviewed technical whitepapers, or watch the quantum engine in action via our tutorials. Whether you're debugging a phonon dispersion or setting up a high-throughput workflow, our engineering team is on standby.</p>
    </section>
  </FormalBrief>
</BaseLayout>
