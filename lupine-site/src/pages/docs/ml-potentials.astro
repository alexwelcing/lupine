---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const pipelineNodes = [
  { title: 'DFT DATA', icon: '01' },
  { title: 'ENGINEERING', icon: '02' },
  { title: 'TRAINING', icon: '03' },
  { title: 'VALIDATION', icon: '04' },
  { title: 'DEPLOY', icon: '05' }
];

const pipelineLogs = [
  { text: '> INITIALIZATION: Ground truth generation via DFT.' },
  { text: '> MAPPING: Local descriptor mapping applied.' },
  { text: '> EXECUTION: Neural potential fitting.' },
  { text: '> CHECK: Force/Stress consistency validated.' },
  { text: '> FINAL: LAMMPS integration complete.' }
];

const benchmarksData = [
  { parameter: 'NequIP', reference: '12.5 h', observed: '45.2 ms', delta: 'O(N)', deltaState: 'warn' as const },
  { parameter: 'Allegro', reference: '8.2 h', observed: '4.1 ms', delta: 'Strictly Local', deltaState: 'good' as const },
  { parameter: 'MACE', reference: '15.0 h', observed: '28.8 ms', delta: 'O(N)', deltaState: 'warn' as const },
  { parameter: 'DeePMD', reference: '4.0 h', observed: '1.5 ms', delta: 'Linear', deltaState: 'good' as const }
];
---

<BaseLayout title="ML Potentials Guide | Lupine Materials Science">
  <FormalBrief
    sealText="LMS // ML ARCHITECTURES"
    title="Machine Learned Potentials"
    subtitle="Bridging quantum accuracy and classical speed with integrated NequIP and Allegro models for next-generation material simulation."
  >
    <div slot="marginalia">
      <p class="font-mono text-[10px] tracking-widest text-secondary mb-2">THE ACCURACY GAP</p>
      <p>Empirical potentials reach 10^7 atoms/sec but lack accuracy. Ab-Initio achieves quantum truth at 10^2 atoms/sec. Lupine ML-potentials bridge this gap with &lt;1meV/atom precision and linear scaling.</p>
    </div>

    <section class="manuscript-section">
      <p>
        Optimizing the Simulation Frontier requires moving beyond classical empirical potentials. Our platform supports the leading equivariant and invariant neural network architectures.
      </p>
      
      <h3>Supported Architectures</h3>
      <ul class="feature-list pl-6 list-disc space-y-4">
        <li><strong>MACE:</strong> Equivariant, 1k-10k Atoms data required, &lt; 1 meV/atom accuracy.</li>
        <li><strong>NequIP:</strong> E(3)-Invariant, 500-2k Atoms data required, ~0.8 meV/atom accuracy.</li>
        <li><strong>Allegro:</strong> Strictly Local, Large Scale data required, &lt; 1.2 meV/atom accuracy.</li>
        <li><strong>DeePMD:</strong> Descriptor-based, 100k+ Conf. data required, 2.5 meV/atom accuracy.</li>
        <li><strong>ANI:</strong> Neural Net, Transferable data required, 1.5 meV/atom accuracy.</li>
      </ul>
    </section>

    <section class="manuscript-section mt-16">
      <WorkflowTimeline 
        title="Training Pipeline"
        statusText="ORCHESTRATION SEQUENCE"
        nodes={pipelineNodes}
        logHeader="PIPELINE LOGS"
        logs={pipelineLogs}
      />
    </section>
    
    <section class="manuscript-section mt-16">
      <h3>Protocol Specification</h3>
      <p>Declarative model definitions ensure reproducible research. Define radial cutoffs, interaction layers, and training hyperparameters in structured YAML configurations.</p>
      <div class="terminal-input mt-6" style="font-family: var(--font-mono); font-size: 0.85rem; padding: 1.5rem; background: var(--surface-container-low); border-radius: 4px; overflow-x: auto; border: 1px solid var(--outline-variant);">
<pre><code class="text-on-surface">model:
  name: allegro
  r_max: 6.0
  num_layers: 3
  env_embed_multiplicity: 8
  latent_dim: 128

training:
  optimizer: Adam
  learning_rate: 0.001
  batch_size: 4
  loss: 
    force_weight: 100
    energy_weight: 1</code></pre>
      </div>
    </section>

    <section class="manuscript-section mt-16">
      <ValidationTable 
        title="Performance Benchmarks"
        summary="Table 4.1: Comparative training and inference metrics across architectures."
        headers={['Architecture', 'Training Time', 'Inference', 'Scaling']}
        rows={benchmarksData}
      />
    </section>
  </FormalBrief>
</BaseLayout>
