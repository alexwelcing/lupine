---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const pipelineNodes = [
  { title: 'Problem Statement', progress: 100 },
  { title: 'Simulation Architecture', progress: 100 },
  { title: 'Aggregated Outputs', progress: 100 }
];

const pipelineLogs = [
  { text: '> Combinatorial Explosion: Billions of possible compositions for MPEAs.' },
  { text: '> Permutation Sweep: Simulated heatmaps and mappings established.' },
  { text: '> Verified Outcomes: 47,000 Compositions Evaluated.' }
];

const metrics = [
  { parameter: 'Compositions Evaluated', reference: 'N/A', observed: '47,000', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Promising Alloys', reference: 'N/A', observed: '12', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Stability Predicted', reference: 'N/A', observed: '1,400°C', delta: 'High', deltaState: 'good' as const },
  { parameter: 'Development Cycles', reference: '12 - 15 Years', observed: '18 - 24 Months', delta: '-85%', deltaState: 'good' as const }
];
---

<BaseLayout title="Aerospace Superalloys | Lupine Research">
  <FormalBrief
    sealText="LMS // AEROSPACE SUPERALLOYS"
    title="Aerospace Superalloys"
    subtitle="Exploring multi-principal element alloys (MPEAs) for high-temperature resilience through massive Permutation sweeps."
  >
    <div slot="marginalia">
      <p>Traditional alloy development relies on single-element bases with minor additions. MPEAs defy this, creating a design space of billions of possibilities.</p>
    </div>

    <section class="manuscript-section">
      <p>
        Lupine’s materials acceleration engine compresses the standard R&D timeline. By utilizing massive permutation sweeps, we identify superior alloys before the first crucible is ever heated, reducing the cycle from laboratory to flight certification by nearly 85%.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <WorkflowTimeline 
        title="Simulation Pipeline"
        statusText="SWEEP COMPLETE"
        nodes={pipelineNodes}
        logHeader="RUNTIME LOGS"
        logs={pipelineLogs}
      />
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Verified Outcomes"
        summary="Table 2.1: Aggregated outputs from MPEA permutation sweeps."
        headers={['Specification', 'Legacy Baseline', 'Lupine Value', 'Delta']}
        rows={metrics}
      />
    </section>
  </FormalBrief>
</BaseLayout>
