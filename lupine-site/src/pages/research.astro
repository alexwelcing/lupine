          rows={table1Rows}
        />
      </div>

      <p>Figure 1 shows eigenvalue spectra on log scale with geometric fits. The near-linear decay confirms the hyper-ribbon structure.</p>
      <div class="my-8 relative overflow-hidden glass-card rounded-lg border border-outline-variant/50 bg-[var(--surface-container-low)] p-6 group">
