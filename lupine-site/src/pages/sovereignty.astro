---
import DarkLayout from '../layouts/DarkLayout.astro';
import Header from '../components/Header.astro';
---

<DarkLayout title="LUPINE MS // SOVEREIGNTY PROTOCOL">
  <Header />

  <main class="pt-28 pb-32 scanline">
    <!-- HERO SECTION -->
    <section class="relative px-12 py-24 mb-12">
      <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="relative z-10">
          <div class="inline-block px-3 py-1 mb-6 bg-surface-container-highest border-l-4 border-tertiary">
            <span class="font-mono-tech text-xs tracking-tighter text-tertiary">MATERIALS SOVEREIGNTY // MT-SR-01</span>
          </div>
          <h1 class="text-6xl md:text-8xl font-serif-italic text-on-surface mb-8 -ml-1 leading-tight">
            Strategic <br/> Sovereignty
          </h1>
          <p class="text-xl md:text-2xl text-on-surface-variant font-light max-w-lg mb-12 leading-relaxed">
            National security relies on independent computational materials infrastructure. We provide the engine for sovereign advancement.
          </p>
          <div class="flex gap-6">
            <button class="metallic-gradient text-on-primary font-mono-tech text-sm px-8 py-4 tracking-widest font-bold">
              EXECUTE PROTOCOL
            </button>
            <button class="ghost-border px-8 py-4 font-mono-tech text-sm tracking-widest text-primary hover:bg-primary/5 transition-all">
              VIEW VISION
            </button>
          </div>
        </div>
        <div class="relative h-[600px] ghost-border group">
          <img class="w-full h-full object-cover grayscale brightness-50 group-hover:grayscale-0 transition-all duration-700" data-alt="Abstract microscopic view of metallic crystal lattice structure with bioluminescent indigo and cyan data trails pulsing through it" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCLdRPPUlQDgmseT1ML8L-FYLcv1Osp5O1QKQWc1UUA3H3djzJlhXYdDmfxNycMoUecUxse06K9wTvKpe8bPrSBTQhhXeUFdBCclt_zFRiCyxyOFjevVAMPcj6oHxNAyt4FNIBackV34BViibQC0x1ruhRV8tIxF3csENr8be_9Am0pX6Ta5pxMJ00Agk4qbjNnHpMIhz3AAtZ_oUDJFBDKueEdZWWnkH0gZgdigaxGgCE-Q6zgnSfYlZ7cY9VUrQt408SeTtO26L0"/>
          <div class="absolute top-4 left-4 font-mono-tech text-[10px] text-secondary">ID: LP-INF-882</div>
          <div class="absolute bottom-4 right-4 font-mono-tech text-[10px] text-secondary">TIMESTAMP: 2024.11.14.04:00</div>
          <div class="absolute top-0 right-0 w-24 h-24 border-t border-r border-secondary/30"></div>
          <div class="absolute bottom-0 left-0 w-24 h-24 border-b border-l border-secondary/30"></div>
        </div>
      </div>
    </section>

    <!-- THREAT ASSESSMENT -->
    <section class="px-12 py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="mb-20 flex justify-between items-end border-b border-outline-variant/20 pb-8">
          <h2 class="text-4xl font-serif-italic">Threat Assessment</h2>
          <span class="font-mono-tech text-xs text-error animate-pulse">CLASSIFIED // EYES ONLY</span>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Card 1 -->
          <div class="glass-pane p-10 flex flex-col h-full relative overflow-hidden">
            <div class="mb-12">
              <span class="material-symbols-outlined text-4xl text-tertiary">public</span>
            </div>
            <h3 class="text-2xl font-serif-italic mb-4">Foreign Supply Chains</h3>
            <p class="text-sm text-on-surface-variant font-light mb-8 flex-grow">Rare earth concentration in adversarial jurisdictions poses a critical vulnerability to domestic hardware production.</p>
            <div class="mt-auto pt-6 border-t border-outline-variant/10">
              <div class="flex justify-between items-center">
                <span class="font-mono-tech text-[10px] text-tertiary">RISK LEVEL: SEVERE</span>
                <span class="font-mono-tech text-[10px]">TH-A1</span>
              </div>
            </div>
          </div>
          <!-- Card 2 -->
          <div class="glass-pane p-10 flex flex-col h-full relative overflow-hidden">
            <div class="mb-12">
              <span class="material-symbols-outlined text-4xl text-secondary">terminal</span>
            </div>
            <h3 class="text-2xl font-serif-italic mb-4">Legacy Toolchains</h3>
            <p class="text-sm text-on-surface-variant font-light mb-8 flex-grow">FORTRAN-era computational legacy introduces memory-unsafe vulnerabilities in core national security simulations.</p>
            <div class="mt-auto pt-6 border-t border-outline-variant/10">
              <div class="flex justify-between items-center">
                <span class="font-mono-tech text-[10px] text-secondary">STATUS: DEPRECATED</span>
                <span class="font-mono-tech text-[10px]">TH-B7</span>
              </div>
            </div>
          </div>
          <!-- Card 3 -->
          <div class="glass-pane p-10 flex flex-col h-full relative overflow-hidden">
            <div class="mb-12">
              <span class="material-symbols-outlined text-4xl text-primary">encrypted</span>
            </div>
            <h3 class="text-2xl font-serif-italic mb-4">Data Sovereignty</h3>
            <p class="text-sm text-on-surface-variant font-light mb-8 flex-grow">Cloud-dependent R&amp;D exposes proprietary IP to extra-territorial legal reach and industrial espionage.</p>
            <div class="mt-auto pt-6 border-t border-outline-variant/10">
              <div class="flex justify-between items-center">
                <span class="font-mono-tech text-[10px] text-primary">VECTOR: EXTERNAL</span>
                <span class="font-mono-tech text-[10px]">TH-C4</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- THE LUPINE SOLUTION -->
    <section class="px-12 py-32">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-20 items-center">
        <div class="md:w-1/2">
          <h2 class="text-5xl font-serif-italic mb-12">The Lupine Solution</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-6 p-6 surface-container-high ghost-border group hover:bg-surface-container-highest transition-colors">
              <span class="font-mono-tech text-xl text-primary">01</span>
              <div>
                <h4 class="font-bold text-lg mb-2">Apache 2.0 Open Source</h4>
                <p class="text-sm text-on-surface-variant">Core primitives for materials simulation, fully auditable and royalty-free.</p>
              </div>
            </div>
            <div class="flex items-start gap-6 p-6 surface-container-high ghost-border group hover:bg-surface-container-highest transition-colors">
              <span class="font-mono-tech text-xl text-secondary">02</span>
              <div>
                <h4 class="font-bold text-lg mb-2">On-Premise Deployment</h4>
                <p class="text-sm text-on-surface-variant">Host your entire simulation pipeline on secure, internal infrastructure.</p>
              </div>
            </div>
            <div class="flex items-start gap-6 p-6 surface-container-high ghost-border group hover:bg-surface-container-highest transition-colors">
              <span class="font-mono-tech text-xl text-tertiary">03</span>
              <div>
                <h4 class="font-bold text-lg mb-2">Rust Memory Safety</h4>
                <p class="text-sm text-on-surface-variant">Eliminating 70% of historical software vulnerabilities at the compiler level.</p>
              </div>
            </div>
            <div class="flex items-start gap-6 p-6 surface-container-high ghost-border group hover:bg-surface-container-highest transition-colors">
              <span class="font-mono-tech text-xl text-primary">04</span>
              <div>
                <h4 class="font-bold text-lg mb-2">Air-Gapped HPC Compatibility</h4>
                <p class="text-sm text-on-surface-variant">Optimized for high-performance computing without external network dependencies.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="md:w-1/2 relative">
          <div class="aspect-square w-full bg-slate-900 overflow-hidden ghost-border relative">
            <img class="w-full h-full object-cover opacity-60" data-alt="Sleek server rack glowing with neon cyan and indigo lights in a dark data center environment" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD_kvfld9JsBFS6QKuArnBxHzPIS7P55avVipBNuoOcFVMrmQR8QxdlW59nkOsMgYyZfKqSiZ4warf6VtVJJ4iPQ4EEAORIGwIu8-Unb2E8iZWcUII6IQWXi66CRZxiyV--rAzOXdRQviiKaoRFwsOsHeITpmMWqddyGmCCmnN07rTNSpTKvVn-GqXtmSU9arqw1QG1jlq2o6UIoHoWg6jWGwpTsnRPPazl4Hv4Ydo-L8nTZ4VOnej8iXlJO0_21WSpl1qvEQZqbR4"/>
            <div class="absolute inset-0 bg-gradient-to-t from-surface-dim to-transparent"></div>
            <!-- HUD Elements -->
            <div class="absolute top-4 left-4 font-mono-tech text-[8px] text-secondary">X: 122.90 | Y: 44.02</div>
            <div class="absolute top-4 right-4 font-mono-tech text-[8px] text-secondary">LAT: 0.002881</div>
            <div class="absolute bottom-4 left-4 font-mono-tech text-[8px] text-secondary">STATUS: OPTIMAL</div>
            <div class="absolute bottom-4 right-4 font-mono-tech text-[8px] text-secondary">FREQ: 5.4 GHZ</div>
          </div>
        </div>
      </div>
    </section>

    <!-- DEFENSE USE CASES -->
    <section class="px-12 py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="mb-20 text-center">
          <h2 class="text-5xl font-serif-italic mb-4">Defense Use Cases</h2>
          <p class="font-mono-tech text-xs tracking-widest text-on-surface-variant">MISSION CRITICAL APPLICATION PORTFOLIO</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-outline-variant/10 border border-outline-variant/10">
          <!-- Card 1 -->
          <div class="bg-surface p-12 hover:bg-surface-container-high transition-colors">
            <div class="flex justify-between items-start mb-8">
              <h3 class="text-2xl font-serif-italic">Hypersonic Materials</h3>
              <span class="font-mono-tech text-xs text-primary">MS-771</span>
            </div>
            <p class="text-sm text-on-surface-variant mb-12">Simulation of thermal protection systems under extreme Mach 5+ heat flux conditions.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="border-l border-primary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-primary">TEMP TOLERANCE</div>
                <div class="font-mono-tech text-lg">3400°K</div>
              </div>
              <div class="border-l border-primary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-primary">EROSION RATE</div>
                <div class="font-mono-tech text-lg">&lt;0.1mm/s</div>
              </div>
            </div>
          </div>
          <!-- Card 2 -->
          <div class="bg-surface p-12 hover:bg-surface-container-high transition-colors">
            <div class="flex justify-between items-start mb-8">
              <h3 class="text-2xl font-serif-italic">Armor Ceramics</h3>
              <span class="font-mono-tech text-xs text-secondary">MS-812</span>
            </div>
            <p class="text-sm text-on-surface-variant mb-12">Dynamic fracture modeling for next-generation ballistic impact resistance.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="border-l border-secondary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-secondary">HARDNESS</div>
                <div class="font-mono-tech text-lg">24.1 GPa</div>
              </div>
              <div class="border-l border-secondary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-secondary">WEIGHT REDUC.</div>
                <div class="font-mono-tech text-lg">42%</div>
              </div>
            </div>
          </div>
          <!-- Card 3 -->
          <div class="bg-surface p-12 hover:bg-surface-container-high transition-colors">
            <div class="flex justify-between items-start mb-8">
              <h3 class="text-2xl font-serif-italic">Jet Engine Alloys</h3>
              <span class="font-mono-tech text-xs text-tertiary">MS-044</span>
            </div>
            <p class="text-sm text-on-surface-variant mb-12">Creep analysis for high-pressure turbine blades in high-bypass powerplants.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="border-l border-tertiary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-tertiary">CYCLE LIFE</div>
                <div class="font-mono-tech text-lg">+2,500H</div>
              </div>
              <div class="border-l border-tertiary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-tertiary">OXIDATION R.</div>
                <div class="font-mono-tech text-lg">ULTRA-LOW</div>
              </div>
            </div>
          </div>
          <!-- Card 4 -->
          <div class="bg-surface p-12 hover:bg-surface-container-high transition-colors">
            <div class="flex justify-between items-start mb-8">
              <h3 class="text-2xl font-serif-italic">Radiation Shielding</h3>
              <span class="font-mono-tech text-xs text-primary">MS-909</span>
            </div>
            <p class="text-sm text-on-surface-variant mb-12">Multi-physics analysis for deep-space and high-altitude electronic protection.</p>
            <div class="grid grid-cols-2 gap-4">
              <div class="border-l border-primary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-primary">ATTENUATION</div>
                <div class="font-mono-tech text-lg">99.9%</div>
              </div>
              <div class="border-l border-primary/30 pl-4 py-1">
                <div class="font-mono-tech text-[10px] text-primary">MASS EFF.</div>
                <div class="font-mono-tech text-lg">8.2x</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CLASSIFICATION TIERS -->
    <section class="px-12 py-32">
      <div class="max-w-5xl mx-auto">
        <div class="flex flex-col md:flex-row items-center gap-4 mb-16">
          <div class="h-[1px] flex-grow bg-outline-variant/30"></div>
          <h2 class="text-3xl font-serif-italic px-6">Classification Deployment Scale</h2>
          <div class="h-[1px] flex-grow bg-outline-variant/30"></div>
        </div>
        <div class="relative py-20 px-8 bg-surface-container-low border border-outline-variant/10">
          <!-- Progress Scale Line -->
          <div class="absolute top-1/2 left-0 w-full h-[2px] bg-outline-variant/20 -translate-y-1/2"></div>
          <div class="relative grid grid-cols-3 gap-8">
            <div class="text-center">
              <div class="w-16 h-16 glass-pane border border-primary mx-auto flex items-center justify-center mb-6 relative z-10">
                <span class="material-symbols-outlined text-primary">cloud</span>
              </div>
              <h4 class="font-mono-tech text-xs mb-2">UNCLASSIFIED</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-widest">Public Cloud Infrastructure</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 glass-pane border border-secondary mx-auto flex items-center justify-center mb-6 relative z-10">
                <span class="material-symbols-outlined text-secondary">security</span>
              </div>
              <h4 class="font-mono-tech text-xs mb-2">CUI</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-widest">GovCloud &amp; Controlled Unclassified</p>
            </div>
            <div class="text-center">
              <div class="w-16 h-16 metallic-gradient mx-auto flex items-center justify-center mb-6 relative z-10 shadow-[0_0_20px_rgba(85,101,212,0.4)]">
                <span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">lock</span>
              </div>
              <h4 class="font-mono-tech text-xs mb-2">SECRET</h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-widest">Air-Gapped &amp; TS/SCI Node Deployment</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="px-12 py-32">
      <div class="max-w-4xl mx-auto glass-pane p-16 text-center border-t-2 border-primary">
        <h2 class="text-5xl font-serif-italic mb-8">Secure the Future</h2>
        <p class="text-on-surface-variant mb-12 max-w-xl mx-auto">Connect with our defense integration team for a technical overview of the Sovereign Protocol and custom deployment options.</p>
        <button class="metallic-gradient text-on-primary font-mono-tech text-sm px-12 py-6 tracking-[0.2em] font-bold hover:scale-105 transition-transform">
          REQUEST DEFENSE BRIEFING
        </button>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="bg-slate-950 border-t border-indigo-900/30 w-full px-12 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="font-mono-tech text-[10px] uppercase tracking-[0.2em] text-slate-600">
      ©2024 LUPINE MATERIALS SCIENCE // CLASSIFIED SOVEREIGNTY PROTOCOL. ALL RIGHTS RESERVED.
    </div>
    <div class="flex gap-8">
      <a class="font-mono-tech text-[10px] uppercase tracking-[0.2em] text-slate-600 hover:text-indigo-400 underline underline-offset-4" href="/sovereignty">CLEARANCE LEVEL IV</a>
      <a class="font-mono-tech text-[10px] uppercase tracking-[0.2em] text-slate-600 hover:text-indigo-400 underline underline-offset-4" href="/docs">DEEP TECH REPOSITORY</a>
      <a class="font-mono-tech text-[10px] uppercase tracking-[0.2em] text-slate-600 hover:text-indigo-400 underline underline-offset-4" href="/">SECURE NODE</a>
    </div>
  </footer>
</DarkLayout>
