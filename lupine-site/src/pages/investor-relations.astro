---
import DarkLayout from '../layouts/DarkLayout.astro';
import Header from '../components/Header.astro';
---

<DarkLayout title="Lupine Materials Science — Investor Relations">
  <Header />
  
  <main class="scanline">
    <!-- Hero Section -->
    <header class="relative pt-48 pb-32 px-12 hero-gradient min-h-[921px] flex flex-col justify-center">
      <div class="max-w-screen-2xl mx-auto w-full grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-8">
          <span class="font-mono-tech text-tertiary text-xs tracking-[0.3em] uppercase mb-6 block">INVESTOR RELATIONS</span>
          <h1 class="text-6xl md:text-8xl font-serif-italic text-on-surface leading-[1.1] mb-8 tech-reveal glitch-decode" data-text="Investor Relations">
            Investor Relations
          </h1>
          <p class="text-xl md:text-2xl text-on-surface-variant max-w-2xl leading-relaxed font-light">
            Unified computational platform for next-century materials. Access secure data rooms, capitalization details, and deep-tech diligence materials.
          </p>
          <div class="mt-12 flex gap-6 tech-reveal" style="animation-delay: 0.2s">
            <button class="kinetic-hover bg-gradient-to-r from-primary to-primary-container text-on-primary px-8 py-4 font-mono-tech text-sm uppercase tracking-widest hover:opacity-90 transition-all" onclick="alert('Feature Coming Soon')">
              Request Diligence
            </button>
            <button class="kinetic-hover bg-surface-container-high border border-outline-variant/20 text-on-surface px-8 py-4 font-mono-tech text-sm uppercase tracking-widest transition-all" onclick="alert('Feature Coming Soon')">
              View Roadmap
            </button>
          </div>
        </div>
        <div class="md:col-span-4 hidden md:block">
          <div class="glass-pane p-8 rounded-lg relative overflow-hidden">
            <div class="absolute inset-0 opacity-10" data-alt="abstract visualization of atomic molecular structures and computational nodal networks in dark blue and violet tones"></div>
            <div class="relative z-10">
              <div class="font-mono-tech text-[10px] text-secondary mb-4">SYSTEM_STATUS: NOMINAL</div>
              <div class="space-y-4">
                <div class="h-1 w-full bg-surface-variant rounded-full overflow-hidden">
                  <div class="h-full bg-secondary w-3/4"></div>
                </div>
                <div class="text-xs font-mono-tech text-on-surface-variant flex justify-between">
                  <span>SIMULATION_LOAD</span>
                  <span>74.2%</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>
    
    <!-- The Thesis -->
    <section class="py-32 px-12 bg-surface-container-low">
      <div class="max-w-4xl mx-auto text-center">
        <span class="font-mono-tech text-[10px] text-primary/60 uppercase tracking-widest mb-12 block">Strategic Vision</span>
        <blockquote class="text-4xl md:text-6xl font-serif-italic leading-tight text-on-surface">
          "Civilization runs on materials. Lupine is the only <span class="text-primary">unified computational platform</span> capable of accelerating discovery at the speed of software."
        </blockquote>
        <div class="mt-12 w-24 h-px bg-gradient-to-r from-transparent via-outline-variant to-transparent mx-auto"></div>
      </div>
    </section>

    <!-- Market Opportunity -->
    <section class="py-32 px-12">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
          <div>
            <span class="font-mono-tech text-[10px] text-secondary uppercase tracking-widest mb-4 block">Market Opportunity</span>
            <h2 class="text-4xl font-serif-italic">Scaling the physical <span class="text-secondary">frontier</span></h2>
          </div>
          <div class="text-right font-mono-tech text-xs text-on-surface-variant">
            SOURCE: Q4 2023 MATERIAL ANALYTICS REPORT [CONFIDENTIAL]
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Card 1 -->
          <div class="spotlight-card glass-pane p-8 relative group overflow-hidden transition-all duration-500 hover:translate-y-[-4px] kinetic-hover">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 blur-[60px] rounded-full -mr-16 -mt-16 group-hover:bg-secondary/20 transition-all cyan-glow"></div>
            <div class="font-mono-tech text-4xl text-primary mb-2 scramble-target" data-final="12B">0</div>
            <div class="font-mono-tech text-[10px] uppercase tracking-tighter text-on-surface-variant mb-6">TAM by 2028</div>
            <p class="text-sm text-on-surface-variant/80 font-light">Rapid expansion across aerospace, battery tech, and semiconductor verticals.</p>
          </div>
          <!-- Card 2 -->
          <div class="spotlight-card glass-pane p-8 relative group overflow-hidden transition-all duration-500 hover:translate-y-[-4px] kinetic-hover">
            <div class="absolute top-0 right-0 w-32 h-32 bg-violet-500/10 blur-[60px] rounded-full -mr-16 -mt-16 group-hover:bg-violet-500/20 transition-all cyan-glow"></div>
            <div class="font-mono-tech text-4xl text-violet-400 mb-2 scramble-target" data-final="300K+">0</div>
            <div class="font-mono-tech text-[10px] uppercase tracking-tighter text-on-surface-variant mb-6">LAMMPS researchers</div>
            <p class="text-sm text-on-surface-variant/80 font-light">Massive existing user base awaiting modern computational orchestration.</p>
          </div>
          <!-- Card 3 -->
          <div class="spotlight-card glass-pane p-8 relative group overflow-hidden transition-all duration-500 hover:translate-y-[-4px] kinetic-hover">
            <div class="absolute top-0 right-0 w-32 h-32 bg-secondary/10 blur-[60px] rounded-full -mr-16 -mt-16 group-hover:bg-tertiary/20 transition-all cyan-glow"></div>
            <div class="font-mono-tech text-4xl text-secondary mb-2 scramble-target" data-final="0">0</div>
            <div class="font-mono-tech text-[10px] uppercase tracking-tighter text-on-surface-variant mb-6">unified competitors</div>
            <p class="text-sm text-on-surface-variant/80 font-light">Fragmented legacy tools create a unique vacuum for Lupine's OS.</p>
          </div>
          <!-- Card 4 -->
          <div class="spotlight-card glass-pane p-8 relative group overflow-hidden transition-all duration-500 hover:translate-y-[-4px] kinetic-hover">
            <div class="absolute top-0 right-0 w-32 h-32 bg-tertiary/10 blur-[60px] rounded-full -mr-16 -mt-16 group-hover:bg-primary/20 transition-all cyan-glow"></div>
            <div class="font-mono-tech text-4xl text-tertiary mb-2 scramble-target" data-final="100x">0</div>
            <div class="font-mono-tech text-[10px] uppercase tracking-tighter text-on-surface-variant mb-6">ML speedup vs DFT</div>
            <p class="text-sm text-on-surface-variant/80 font-light">Proprietary neural potentials bypass traditional quantum bottlenecks.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Roadmap -->
    <section class="py-32 px-12 bg-surface-container-lowest overflow-hidden relative">
      <div class="max-w-screen-2xl mx-auto">
        <div class="mb-20">
          <span class="font-mono-tech text-[10px] text-primary uppercase tracking-widest mb-4 block">Product Roadmap</span>
          <h2 class="text-4xl font-serif-italic">From code to <span class="italic">substance</span></h2>
        </div>
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute top-0 left-8 md:left-1/2 md:-translate-x-1/2 h-full w-px bg-outline-variant/20"></div>
          <div class="space-y-24 relative z-10">
            <!-- Event 1 -->
            <div class="flex flex-col md:flex-row md:items-center">
              <div class="md:w-1/2 pr-0 md:pr-16 text-left md:text-right mb-4 md:mb-0">
                <span class="font-mono-tech text-secondary text-xs bg-secondary/10 px-3 py-1 rounded-full uppercase">Shipped</span>
                <h3 class="text-2xl font-serif-italic mt-4">Lupine View shipped</h3>
                <p class="text-on-surface-variant mt-2 max-w-sm md:ml-auto">Real-time atomic visualization engine for collaborative research.</p>
              </div>
              <div class="w-16 h-16 rounded-full bg-surface-container border-4 border-background flex items-center justify-center shrink-0 mx-0 md:mx-auto">
                <span class="material-symbols-outlined text-secondary">check_circle</span>
              </div>
              <div class="md:w-1/2 pl-0 md:pl-16">
                <span class="font-mono-tech text-on-surface-variant text-xs">PRESENT</span>
              </div>
            </div>
            <!-- Event 2 -->
            <div class="flex flex-col md:flex-row-reverse md:items-center">
              <div class="md:w-1/2 pl-0 md:pl-16 text-left mb-4 md:mb-0">
                <span class="font-mono-tech text-primary text-xs bg-primary/10 px-3 py-1 rounded-full uppercase">Building</span>
                <h3 class="text-2xl font-serif-italic mt-4">MD Engine alpha</h3>
                <p class="text-on-surface-variant mt-2 max-w-sm">Next-gen Molecular Dynamics integration with ML-enhanced force fields.</p>
              </div>
              <div class="w-16 h-16 rounded-full bg-surface-container border-4 border-background flex items-center justify-center shrink-0 mx-0 md:mx-auto">
                <span class="material-symbols-outlined text-primary">engineering</span>
              </div>
              <div class="md:w-1/2 pr-0 md:pr-16 text-left md:text-right">
                <span class="font-mono-tech text-on-surface-variant text-xs">+6 MO</span>
              </div>
            </div>
            <!-- Event 3 -->
            <div class="flex flex-col md:flex-row md:items-center">
              <div class="md:w-1/2 pr-0 md:pr-16 text-left md:text-right mb-4 md:mb-0">
                <span class="font-mono-tech text-on-surface-variant/60 text-xs bg-surface-variant px-3 py-1 rounded-full uppercase">Planned</span>
                <h3 class="text-2xl font-serif-italic mt-4">DFT + ML pipeline</h3>
                <p class="text-on-surface-variant mt-2 max-w-sm md:ml-auto">Density Functional Theory automation with active learning loops.</p>
              </div>
              <div class="w-16 h-16 rounded-full bg-surface-container border-4 border-background flex items-center justify-center shrink-0 mx-0 md:mx-auto">
                <span class="material-symbols-outlined text-outline">calendar_today</span>
              </div>
              <div class="md:w-1/2 pl-0 md:pl-16">
                <span class="font-mono-tech text-on-surface-variant text-xs">+12 MO</span>
              </div>
            </div>
            <!-- Event 4 -->
            <div class="flex flex-col md:flex-row-reverse md:items-center">
              <div class="md:w-1/2 pl-0 md:pl-16 text-left mb-4 md:mb-0">
                <span class="font-mono-tech text-on-surface-variant/60 text-xs bg-surface-variant px-3 py-1 rounded-full uppercase">Planned</span>
                <h3 class="text-2xl font-serif-italic mt-4">Unified enterprise platform</h3>
                <p class="text-on-surface-variant mt-2 max-w-sm">Full-stack material operating system for Fortune 500 R&amp;D.</p>
              </div>
              <div class="w-16 h-16 rounded-full bg-surface-container border-4 border-background flex items-center justify-center shrink-0 mx-0 md:mx-auto">
                <span class="material-symbols-outlined text-outline">hub</span>
              </div>
              <div class="md:w-1/2 pr-0 md:pr-16 text-left md:text-right">
                <span class="font-mono-tech text-on-surface-variant text-xs">+24 MO</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team & Advisors -->
    <section class="py-32 px-12">
      <div class="max-w-screen-2xl mx-auto">
        <div class="text-center mb-24">
          <span class="font-mono-tech text-[10px] text-tertiary uppercase tracking-widest mb-4 block">Founding Team</span>
          <h2 class="text-5xl font-serif-italic">The <span class="text-tertiary">Architects</span></h2>
        </div>
        <div class="flex justify-center">
          <!-- Founder 1 -->
          <div class="group max-w-sm w-full mx-auto">
            <div class="font-serif-italic text-2xl mb-1 text-center mt-12">Alex Welcing</div>
            <div class="font-mono-tech text-[10px] text-primary uppercase tracking-widest mb-4 text-center">Founder / High-Performance Systems &amp; 3D Architecture</div>
            <div class="h-px w-8 bg-outline-variant mb-4 group-hover:w-full transition-all duration-500 mx-auto"></div>
          </div>
        </div>
        <!-- Institutional Logos -->
        <div class="mt-32 pt-16 border-t border-outline-variant/10">
          <div class="flex flex-wrap justify-center gap-16 opacity-30 grayscale">
            <div class="font-mono-tech text-xl font-bold">MIT</div>
            <div class="font-mono-tech text-xl font-bold">STANFORD</div>
            <div class="font-mono-tech text-xl font-bold">NASA</div>
            <div class="font-mono-tech text-xl font-bold">CALTECH</div>
            <div class="font-mono-tech text-xl font-bold">CERN</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Data Room Access -->
    <section class="py-32 px-12 bg-surface-container-low">
      <div class="max-w-4xl mx-auto">
        <div class="glass-pane p-12 md:p-20 rounded-xl relative overflow-hidden border-t border-primary/20">
          <div class="absolute -top-24 -left-24 w-64 h-64 bg-primary/5 blur-[80px] rounded-full"></div>
          <div class="relative z-10 text-center">
            <span class="material-symbols-outlined text-4xl text-primary mb-8" style="font-variation-settings: 'FILL' 1;">encrypted</span>
            <h2 class="text-4xl font-serif-italic mb-6">Request access to confidential data room</h2>
            <p class="text-on-surface-variant mb-12 max-w-lg mx-auto leading-relaxed">
              Access detailed capitalization tables, IP filings, and 3rd party computational validation reports. Requires signed MNDA.
            </p>
            <form class="flex flex-col md:flex-row gap-4 max-w-md mx-auto" onsubmit="event.preventDefault(); alert('Feature Coming Soon');">
              <input class="flex-grow bg-surface-container-lowest border-none border-b border-outline-variant/30 text-on-surface px-6 py-4 focus:ring-0 focus:border-[#00daf3] focus:shadow-[0_4px_16px_rgba(0,218,243,0.2)] transition-all font-mono-tech text-sm" placeholder="Institutional Email" type="email"/>
              <button class="kinetic-hover bg-primary text-on-primary px-8 py-4 font-mono-tech text-sm uppercase tracking-widest transition-all">
                Submit Request
              </button>
            </form>
            <!-- Security Badges -->
            <div class="mt-16 flex flex-wrap justify-center gap-8 items-center">
              <div class="flex items-center gap-2 font-mono-tech text-[9px] text-on-surface-variant/40 uppercase tracking-widest">
                <span class="material-symbols-outlined text-sm">verified_user</span> SOC2 TYPE II
              </div>
              <div class="flex items-center gap-2 font-mono-tech text-[9px] text-on-surface-variant/40 uppercase tracking-widest">
                <span class="material-symbols-outlined text-sm">security</span> ITAR COMPLIANT
              </div>
              <div class="flex items-center gap-2 font-mono-tech text-[9px] text-on-surface-variant/40 uppercase tracking-widest">
                <span class="material-symbols-outlined text-sm">lock</span> AES-256
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Data Hydration Script -->
  <script>
    document.addEventListener("astro:page-load", () => {
      const targets = document.querySelectorAll('.scramble-target');
      const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&*";
      
      // Spotlight Logic
      const spotlights = document.querySelectorAll('.spotlight-card');
      document.addEventListener('mousemove', (e) => {
        spotlights.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if(entry.isIntersecting) {
            const el = entry.target;
            const final = el.getAttribute('data-final');
            if (!final || el.hasAttribute('data-scrambled')) return;
            el.setAttribute('data-scrambled', 'true');
            
            let iteration = 0;
            const interval = setInterval(() => {
              el.innerText = final.split("")
                .map((letter, index) => {
                  if(index < iteration) {
                    return final[index];
                  }
                  return chars[Math.floor(Math.random() * chars.length)];
                })
                .join("");
              
              if(iteration >= final.length){
                clearInterval(interval);
              }
              iteration += 1 / 3;
            }, 30);
          }
        });
      }, { threshold: 0.5 });

      targets.forEach(t => observer.observe(t));
    });
  </script>

  <!-- Footer -->
  <footer class="bg-[#12131a] w-full py-16 px-12 border-t border-[#e3e1ec]/10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 w-full max-w-screen-2xl mx-auto">
      <div class="col-span-1 lg:col-span-1">
        <div class="text-xl font-serif italic text-[#e3e1ec] mb-6">Lupine Materials</div>
        <p class="text-sm text-[#e3e1ec]/40 leading-relaxed font-sans">
          Accelerating the physical future through computational sovereignty.
        </p>
      </div>
      <div class="space-y-4">
        <div class="font-mono text-[10px] uppercase text-[#5565d4] tracking-[0.2em] mb-4">Navigation</div>
        <ul class="space-y-2">
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="javascript:void(0);" onclick="alert('Feature Coming Soon')">Thesis</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="/investor-relations">Market</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="javascript:void(0);" onclick="alert('Feature Coming Soon')">Roadmap</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="javascript:void(0);" onclick="alert('Feature Coming Soon')">Team</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <div class="font-mono text-[10px] uppercase text-[#5565d4] tracking-[0.2em] mb-4">Legal &amp; Compliance</div>
        <ul class="space-y-2">
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="/sovereignty">Compliance</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="/">Privacy Policy</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="/contact">Contact</a></li>
          <li><a class="text-[#e3e1ec]/40 hover:text-[#5565d4] transition-opacity text-sm font-sans" href="/investor-relations">SEC Filings</a></li>
        </ul>
      </div>
      <div class="space-y-4">
        <div class="font-mono text-[10px] uppercase text-[#5565d4] tracking-[0.2em] mb-4">Data Protocol</div>
        <div class="glass-pane p-4 rounded bg-surface-container-low border border-outline-variant/10">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-2 h-2 rounded-full bg-secondary animate-pulse"></div>
            <span class="font-mono-tech text-[10px] text-on-surface-variant">NODE_01 ACTIVE</span>
          </div>
          <div class="font-mono-tech text-[10px] text-on-surface-variant/40">Latency: 12ms</div>
        </div>
      </div>
    </div>
    <div class="max-w-screen-2xl mx-auto mt-24 flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="font-mono text-[10px] uppercase text-[#e3e1ec]/40 tracking-wider">
        © 2024 Lupine Materials Science. All rights reserved. Quantum Ledger Precision.
      </div>
      <div class="flex gap-6">
        <a class="text-on-surface-variant/40 hover:text-primary transition-colors" href="#">
          <span class="material-symbols-outlined">terminal</span>
        </a>
        <a class="text-on-surface-variant/40 hover:text-primary transition-colors" href="#">
          <span class="material-symbols-outlined">language</span>
        </a>
      </div>
    </div>
  </footer>
</DarkLayout>
