---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const timelineNodes = [
  { title: 'Kernel Layer', progress: 100 },
  { title: 'Compute Layer', progress: 100 },
  { title: 'Intelligence Layer', progress: 100 },
  { title: 'Interface Layer', progress: 100 }
];

const timelineLogs = [
  { text: '> Rust / WASM Core Runtime initialized.' },
  { text: '> WebGPU / CUDA Accelerated Kernels active.' },
  { text: '> ML Potentials & Neural Networks loaded.' },
  { text: '> Web / CLI / API Endpoints ready.' }
];

const metrics = [
  { parameter: 'Zero-Cost Abstractions', reference: 'N/A', observed: 'Validated', delta: 'Native', deltaState: 'good' as const },
  { parameter: 'Atoms @ 60fps', reference: '250k', observed: '10M+', delta: '40x', deltaState: 'good' as const },
  { parameter: 'Accuracy Benchmarks', reference: '> 50meV', observed: '< 1meV', delta: '-49meV', deltaState: 'good' as const }
];
---

<BaseLayout title="Platform Architecture | Lupine">
  <FormalBrief
    sealText="LMS // KERNEL ARCHITECTURE"
    title="Deep Tech Stack"
    subtitle="Unifying Density Functional Theory (DFT), Machine Learning (ML), and Molecular Dynamics (MD) into a single memory-safe Rust kernel. Precision engineering for the atomic scale."
  >
    <div slot="marginalia">
      <p>System components are strictly decoupled, enforcing a unidirectional flow of state from the Rust kernel to the WebGPU rendering tier.</p>
    </div>

    <section class="manuscript-section">
      <p>
        The Lupine platform represents a fundamental architectural departure from legacy materials science tools. By compiling our core computational physics routines directly to WebAssembly and executing them alongside high-performance WebGPU shaders, we achieve native-level supercomputing within a standard web browser.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <WorkflowTimeline 
        title="System Pipeline & Layer Visualization"
        statusText="PIPELINE ACTIVE"
        nodes={timelineNodes}
        logHeader="RUNTIME LOGS"
        logs={timelineLogs}
      />
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Performance Tolerances"
        summary="Table 1.1: Architecture scale limits validated against standard MD engines."
        headers={['Specification', 'Legacy Baseline', 'Lupine Value', 'Delta']}
        rows={metrics}
      />
    </section>
  </FormalBrief>
</BaseLayout>
