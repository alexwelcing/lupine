---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormalBrief from '../../components/LayoutPrimitives/FormalBrief.astro';
import ValidationTable from '../../components/LayoutPrimitives/ValidationTable.astro';
import WorkflowTimeline from '../../components/LayoutPrimitives/WorkflowTimeline.astro';
import '../../styles/global.css';

const theoremNodes = [
  { title: "Claim 1: Simpson's Paradox", icon: '❌' },
  { title: 'Claim 2: Hyper-Ribbon', icon: '✅' }
];

const theoremLogs = [
  { text: '> syntheticBccEamParadox.simpsonsDetected = false' },
  { text: '> Proof: native_decide' },
  { text: '> satisfiesHyperRibbonClaim fccAllPR 3 = true' },
  { text: '> Proof: native_decide' }
];

const hypothesisTable = [
  { parameter: 'H1', reference: 'Validation Incompleteness', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const },
  { parameter: 'H2', reference: 'Epistemic Entropy Bound', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const },
  { parameter: 'H3', reference: 'Causal Structure Theorem', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const },
  { parameter: 'H4', reference: 'Spectral Rigidity', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const },
  { parameter: 'H5', reference: 'Transferability Phase Transition', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const },
  { parameter: 'H6', reference: 'Bootstrap Collapse', observed: 'Conjecture', delta: 'Pending', deltaState: 'neutral' as const }
];
---

<BaseLayout title="Theorem-Driven Validation | Lupine">
  <FormalBrief
    sealText="LMS // LEAN 4 VERIFICATION"
    title="Proof Before Simulation"
    subtitle="We formalize what it means to validate an interatomic potential — then we lock that formalization into the build. 47 theorems. Zero sorry. One epistemic contract."
  >
    <div slot="marginalia">
      <p>Conventional materials informatics puts claims in PDFs. We put them in Lean 4 modules. If the claim breaks, the build breaks.</p>
    </div>

    <section class="manuscript-section">
      <p>
        Our Open Distillation Factory utilizes Lean 4 to prove the epistemic boundaries of interatomic potentials before any large-scale simulation is run. We formulate rigorous bounds on manifold geometries and prediction error variances, replacing implicit assumptions with explicit, build-locking computational contracts.
      </p>
    </section>

    <section class="manuscript-section mt-12">
      <WorkflowTimeline 
        title="Formal Audit Findings"
        statusText="AUDIT COMPLETE"
        nodes={theoremNodes}
        logHeader="LEAN 4 OUTPUT"
        logs={theoremLogs}
      />
    </section>

    <section class="manuscript-section mt-12">
      <ValidationTable 
        title="Meta-Scientific Hypotheses"
        summary="Table 4.1: Axiomatic conjectures governing prediction errors."
        headers={['Identifier', 'Topic', 'Status', 'Delta']}
        rows={hypothesisTable}
      />
    </section>
  </FormalBrief>
</BaseLayout>
